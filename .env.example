# Revlm 环境变量示例
# 复制为 .env 后按需填写；进程通过环境变量读取（std::getenv），不会自动解析本文件。
# 用法示例：
#   set -a && source .env && set +a && ./revlm
#   docker run --env-file .env ...

# --- 必填 ---
# MySQL DSN: user:pass@tcp(host:port)/db?...
REVLM_DB_DSN=revlm:revlm@tcp(127.0.0.1:3306)/revlm?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# --- 常用可选（括号内为默认值）---
REVLM_ENV=dev
REVLM_ADDR=:8080
# 站点对外 base URL（可空；非空时须带 http:// 或 https://）
# REVLM_SITE_BASE_URL=https://example.com

# Redis：addr 为空时仅单进程本地并发限制；多副本需配置
# REVLM_REDIS_ADDR=127.0.0.1:6379
# REVLM_REDIS_PASSWORD=
REVLM_REDIS_KEY_PREFIX=revlm
REVLM_REDIS_DB=0

# --- 超时 / 连接池 / 网关（一般保持默认即可）---
# REVLM_SHUTDOWN_GRACE_PERIOD_SECONDS=60
# REVLM_HTTP_READ_HEADER_TIMEOUT_SECONDS=5
# REVLM_HTTP_MAX_HEADER_BYTES=1048576
# REVLM_HTTP_MAX_BODY_BYTES=4194304
# REVLM_PROXY_UPSTREAM_TIMEOUT_SECONDS=30
# REVLM_DB_MAX_OPEN_CONNS=64
# REVLM_DB_MAX_IDLE_CONNS=32
# REVLM_GATEWAY_RETRY_BASE_DELAY_MS=300
# REVLM_GATEWAY_RETRY_MAX_DELAY_MS=1500
# REVLM_ROUTING_REBUILD_DEBOUNCE_MS=500

# --- 测试（仅集成测试；未设置则相关 MySQL 测试跳过）---
# REVLM_TEST_MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/revlm_test?parseTime=true&charset=utf8mb4&collation=utf8mb4_unicode_ci

# --- 前端（Vite；在 frontend/ 目录下使用，见 frontend/.env.example）---
# VITE_API_BASE_URL=
